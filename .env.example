# ============================================
# HARAMARA BOT — Variables de entorno
# Copia esto como .env.local y llena los valores
# NUNCA subas .env.local a GitHub (ya está en .gitignore)
# ============================================

# Supabase — https://supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NO la anon)

# Groq — https://console.groq.com (gratis)
GROQ_API_KEY=gsk_...

# Cohere — https://dashboard.cohere.com (gratis, para embeddings)
COHERE_API_KEY=...

# Meta WhatsApp Business Cloud API
# Configura en https://developers.facebook.com
META_VERIFY_TOKEN=haramara_webhook_2025   # tú lo inventas, cualquier string
META_WHATSAPP_TOKEN=EAAx...               # token de acceso permanente (System User)
META_PHONE_NUMBER_ID=1234567890           # ID del número de WhatsApp
WHATSAPP_BUSINESS_ACCOUNT_ID=0987654321

# Tu número de WhatsApp para alertas (con código de país, sin +)
ADMIN_WHATSAPP=56912345678

# Admin panel — invéntate una contraseña segura
ADMIN_SECRET=una_clave_segura_aqui
NEXT_PUBLIC_ADMIN_SECRET=una_clave_segura_aqui   # misma clave (la necesita el cliente)

# URL pública del deploy (necesaria para alertas)
NEXT_PUBLIC_APP_URL=https://haramara-bot.vercel.app
